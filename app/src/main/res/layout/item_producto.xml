<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/unimarket_card"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="1dp"
    app:strokeColor="@color/unimarket_line"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_miniatura"
                android:layout_width="@dimen/product_thumb_size"
                android:layout_height="@dimen/product_thumb_size"
                android:background="@drawable/bg_thumbnail"
                android:gravity="center"
                android:textColor="@color/unimarket_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="LIB" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/texto_categoria"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/unimarket_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Libros" />

                    <TextView
                        android:id="@+id/texto_estado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/unimarket_muted"
                        android:textSize="12sp"
                        tools:text="Usado" />
                </LinearLayout>

                <TextView
                    android:id="@+id/texto_titulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/unimarket_ink"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="Libro de calculo" />

                <TextView
                    android:id="@+id/texto_precio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/unimarket_secondary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="$32.00" />

                <TextView
                    android:id="@+id/texto_descripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="13sp"
                    tools:text="Descripcion corta del producto." />

                <TextView
                    android:id="@+id/texto_vendedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/unimarket_ink"
                    android:textSize="13sp"
                    tools:text="Daniel Ruiz" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_favorito"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Guardar"
            app:icon="@android:drawable/btn_star_big_off"
            app:iconGravity="textStart" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
