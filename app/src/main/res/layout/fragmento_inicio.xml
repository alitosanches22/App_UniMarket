<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unimarket_surface"
    android:fillViewport="true"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Encuentra lo que necesitas"
            android:textColor="@color/unimarket_ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Libros, electronicos, laboratorio y tutorias entre estudiantes."
            android:textColor="@color/unimarket_muted"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/campo_busqueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:hint="Buscar producto"
            app:boxBackgroundMode="outline"
            app:startIconDrawable="@android:drawable/ic_menu_search">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/entrada_busqueda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/grupo_categorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_todo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:checkable="true"
                    android:text="Todo"
                    />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_libros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Libros" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_electronicos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Electronicos" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_laboratorio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Laboratorio" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_tutorias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Tutorias" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_otros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Otros" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_favoritos"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="Favoritos"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_perfil"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Perfil"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="textStart" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_publicar_producto"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Publicar producto"
            app:cornerRadius="@dimen/card_radius"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconGravity="textStart" />

        <LinearLayout
            android:id="@+id/contenedor_productos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/texto_estado_vacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center"
            android:text="No hay productos con esos filtros."
            android:textColor="@color/unimarket_muted"
            android:textSize="15sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
