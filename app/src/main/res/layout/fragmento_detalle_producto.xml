<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unimarket_surface"
    android:fillViewport="true"
    tools:context=".ProductDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_thumbnail">

            <TextView
                android:id="@+id/texto_categoria_principal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/unimarket_primary"
                android:textSize="30sp"
                android:textStyle="bold"
                tools:text="Libros" />
        </FrameLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/contenedor_galeria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/texto_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:textColor="@color/unimarket_ink"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="Calculadora cientifica Casio" />

        <TextView
            android:id="@+id/texto_precio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textColor="@color/unimarket_secondary"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="$18.50" />

        <TextView
            android:id="@+id/texto_descripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/unimarket_ink"
            android:textSize="15sp"
            tools:text="Descripcion completa del producto seleccionado." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_categoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_box"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/unimarket_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Electronicos" />

            <TextView
                android:id="@+id/texto_condicion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_box"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/unimarket_ink"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Usado - bueno" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_vendedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:textColor="@color/unimarket_muted"
            android:textSize="14sp"
            tools:text="Mariana Lopez - Administracion" />

        <LinearLayout
            android:id="@+id/panel_video"
            android:layout_width="match_parent"
            android:layout_height="86dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_video_panel"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video demostrativo disponible"
                android:textColor="@color/unimarket_ink"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_sin_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Sin video demostrativo."
            android:textColor="@color/unimarket_muted"
            android:textSize="14sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_favorito"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Agregar a favoritos"
            app:cornerRadius="@dimen/card_radius"
            app:icon="@android:drawable/btn_star_big_off"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_contactar_vendedor"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Contactar vendedor"
            app:cornerRadius="@dimen/card_radius"
            app:icon="@android:drawable/ic_dialog_email"
            app:iconGravity="textStart" />

        <LinearLayout
            android:id="@+id/grupo_acciones_dueno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_editar_producto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Editar publicacion"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_marcar_vendido"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="Marcar como vendida"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_eliminar_producto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="Eliminar publicacion"
                android:textColor="@color/unimarket_secondary"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                app:iconTint="@color/unimarket_secondary" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
