<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unimarket_surface"
    android:fillViewport="true"
    tools:context=".ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_avatar"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_nombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/unimarket_ink"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Alejandra Mendoza" />

                <TextView
                    android:id="@+id/texto_correo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="13sp"
                    tools:text="alejandra@universidad.edu" />

                <TextView
                    android:id="@+id/texto_carrera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/unimarket_ink"
                    android:textSize="14sp"
                    tools:text="Ingenieria en Sistemas" />

                <TextView
                    android:id="@+id/texto_telefono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="13sp"
                    tools:text="099 555 2301" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_box"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_cantidad_publicaciones"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/unimarket_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Publicaciones"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_box"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_cantidad_ventas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/unimarket_secondary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ventas"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_box"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_cantidad_favoritos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/unimarket_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favoritos"
                    android:textColor="@color/unimarket_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_favoritos"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="Favoritos"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_publicar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Publicar"
                app:cornerRadius="@dimen/card_radius"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Mis publicaciones"
            android:textColor="@color/unimarket_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedor_mis_productos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_editar_perfil"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Editar perfil"
            app:cornerRadius="@dimen/card_radius"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_cerrar_sesion"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Cerrar sesion"
            android:textColor="@color/unimarket_secondary"
            app:cornerRadius="@dimen/card_radius"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconGravity="textStart"
            app:iconTint="@color/unimarket_secondary" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
